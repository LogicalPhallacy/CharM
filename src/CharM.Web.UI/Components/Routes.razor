@using CharM.Web.Services
@inherits CharmComponentBase
@inject RulesDatabaseService RulesDatabase
@rendermode @(AppInteractiveServer)

@if (!RulesDatabase.IsLoaded || RulesDatabase.IsManageMode)
{
    <LayoutView Layout="typeof(Layout.MainLayout)">
        <RulesDatabaseSetup IsManageMode="@RulesDatabase.IsManageMode"
                            OnCancel="HandleCancelManage" />
    </LayoutView>
}
else
{
    <Router AppAssembly="typeof(Routes).Assembly" NotFoundPage="typeof(Pages.NotFound)">
        <Found Context="routeData">
            <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
    </Router>
}

@code {
    protected override void OnInitialized()
    {
        RulesDatabase.Changed += HandleRulesDatabaseChanged;
    }

    private void HandleCancelManage() => RulesDatabase.ExitManageMode();

    private void HandleRulesDatabaseChanged() => NotifyStateChanged();

    protected override void OnDispose()
    {
        RulesDatabase.Changed -= HandleRulesDatabaseChanged;
    }
}
