@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using CharM.Web.Services
@inherits CharmComponentBase
@inject CharacterSessionService SessionService
@inject RulesDatabaseService RulesDatabase
@inject BrowserStorageService Storage
@inject CharacterRestoreState RestoreState
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject DisplaySettingsService DisplaySettings

<div class="flex items-center gap-2">
    <!-- Hidden file input for Import; its label lives in the Character menu. -->
    <InputFile id="dnd4e-import-input"
               OnChange="ImportCharacterAsync"
               class="absolute -left-[9999px] w-px h-px overflow-hidden opacity-0" />

    <!-- Character Management dropdown: New / Import / Export / Copy / Paste -->
    <div class="relative no-print">
        <button @onclick="ToggleCharMenu"
                class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-label font-semibold text-on-surface bg-surface-container-low rounded hover:bg-surface-container-high transition-colors scale-98-active"
                title="Character management">
            <span class="material-symbols-outlined text-lg">manage_accounts</span>
            <span class="hidden sm:inline">Character</span>
            <span class="material-symbols-outlined text-base">@(_charMenuOpen ? "expand_less" : "expand_more")</span>
        </button>
        @if (_charMenuOpen)
        {
            <div class="absolute right-0 mt-1 w-56 z-50 bg-surface-container-lowest rounded shadow-lg ghost-border p-1 text-sm">
                <button @onclick="NewCharacterFromMenu"
                        disabled="@(!RulesDatabase.IsLoaded)"
                        class="w-full flex items-center gap-2 px-3 py-2 text-left font-label font-medium text-on-surface rounded hover:bg-surface-container-low transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
                    <span class="material-symbols-outlined text-lg">add</span>
                    New character
                </button>
                <label for="dnd4e-import-input" @onclick="CloseCharMenu"
                       class="w-full flex items-center gap-2 px-3 py-2 text-left font-label font-medium text-on-surface rounded hover:bg-surface-container-low transition-colors cursor-pointer @(RulesDatabase.IsLoaded ? "" : "opacity-40 pointer-events-none")">
                    <span class="material-symbols-outlined text-lg">upload</span>
                    Import .dnd4e
                </label>
                <button @onclick="ExportCharacterFromMenu"
                        disabled="@(!SessionService.HasSession || !RulesDatabase.IsLoaded)"
                        class="w-full flex items-center gap-2 px-3 py-2 text-left font-label font-medium text-on-surface rounded hover:bg-surface-container-low transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
                    <span class="material-symbols-outlined text-lg">download</span>
                    Export .dnd4e
                </button>
                <button @onclick="CopyAsTextFromMenu"
                        disabled="@(!SessionService.HasSession || !RulesDatabase.IsLoaded)"
                        class="w-full flex items-center gap-2 px-3 py-2 text-left font-label font-medium text-on-surface rounded hover:bg-surface-container-low transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
                    <span class="material-symbols-outlined text-lg">content_copy</span>
                    Copy as text
                </button>
                <button @onclick="PasteTextFromMenu"
                        disabled="@(!RulesDatabase.IsLoaded)"
                        class="w-full flex items-center gap-2 px-3 py-2 text-left font-label font-medium text-on-surface rounded hover:bg-surface-container-low transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
                    <span class="material-symbols-outlined text-lg">content_paste</span>
                    Paste text
                </button>
            </div>
        }
    </div>
    <button @onclick="UndoLastChoice"
            disabled="@(!(SessionService.Session?.ChoiceHistory.Count > 0))"
            class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-label font-semibold text-on-surface bg-surface-container-low rounded hover:bg-surface-container-high transition-colors scale-98-active no-print disabled:opacity-40 disabled:cursor-not-allowed"
            title="Undo last choice">
        <span class="material-symbols-outlined text-lg">undo</span>
        <span class="hidden sm:inline">Undo</span>
    </button>
    <button @onclick="OpenPrintModal"
            disabled="@(!SessionService.HasSession)"
            class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-label font-semibold text-on-primary bg-primary rounded hover:bg-primary-dim transition-colors scale-98-active no-print disabled:opacity-40 disabled:cursor-not-allowed"
            title="Open the printable character sheet">
        <span class="material-symbols-outlined text-lg">print</span>
        <span class="hidden sm:inline">Print</span>
    </button>
    <button @onclick="OpenDisplaySettings"
            class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-label font-semibold text-on-surface bg-surface-container-low rounded hover:bg-surface-container-high transition-colors scale-98-active no-print"
            title="Display settings">
        <span class="material-symbols-outlined text-lg">settings</span>
    </button>
    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <span class="hidden xl:inline text-xs font-label @( _statusIsError ? "text-error" : "text-on-success-container")">
            @_statusMessage
        </span>
    }
</div>

<PrintOptionsModal Show="_showPrintModal"
                   OnCancel="ClosePrintModal"
                   OnConfirm="HandlePrintConfirm" />

<DisplaySettingsModal Show="_showDisplaySettings"
                      OnClose="HandleDisplaySettingsClosed" />

@if (_showPasteTextModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-scrim/60" @onclick="ClosePasteTextModal">
        <div class="bg-surface-container rounded-lg shadow-xl w-full max-w-2xl m-4 p-4" @onclick:stopPropagation="true">
            <h2 class="text-lg font-bold mb-2">Paste SummaryText character</h2>
            <p class="text-xs text-on-surface-variant mb-3">
                Paste an OCB-style SummaryText block (starts with "====== Created Using ..."). The current character will be replaced.
            </p>
            <textarea @bind="_pasteTextBuffer"
                      rows="14"
                      class="w-full p-2 font-mono text-xs bg-surface-container-low rounded border border-outline-variant"
                      placeholder="====== Created Using Wizards of the Coast D&D Character Builder ======&#10;..."></textarea>
            @if (!string.IsNullOrEmpty(_pasteTextStatus))
            {
                <p class="mt-2 text-xs @(_pasteTextStatusIsError ? "text-error" : "text-on-surface-variant")">@_pasteTextStatus</p>
            }
            <div class="flex justify-end gap-2 mt-3">
                <button @onclick="ClosePasteTextModal" class="px-3 py-1.5 text-sm font-semibold rounded bg-surface-container-low hover:bg-surface-container-high">Cancel</button>
                <button @onclick="ImportPastedTextAsync"
                        disabled="@string.IsNullOrWhiteSpace(_pasteTextBuffer)"
                        class="px-3 py-1.5 text-sm font-semibold rounded bg-primary text-on-primary hover:bg-primary-dim disabled:opacity-40">
                    Import
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string? _statusMessage;
    private bool _statusIsError;
    private bool _showPrintModal;
    private bool _showPasteTextModal;
    private string _pasteTextBuffer = string.Empty;
    private string? _pasteTextStatus;
    private bool _pasteTextStatusIsError;
    private bool _charMenuOpen;

    private void ToggleCharMenu() => _charMenuOpen = !_charMenuOpen;
    private void CloseCharMenu() => _charMenuOpen = false;

    // Menu-item wrappers: close the dropdown, then run the existing action.
    private async Task NewCharacterFromMenu()
    {
        CloseCharMenu();
        await StartNewCharacter();
    }

    private async Task ExportCharacterFromMenu()
    {
        CloseCharMenu();
        await ExportCharacterAsync();
    }

    private async Task CopyAsTextFromMenu()
    {
        CloseCharMenu();
        await CopyAsTextAsync();
    }

    private void PasteTextFromMenu()
    {
        CloseCharMenu();
        OpenPasteTextModal();
    }

    private void OpenPasteTextModal()
    {
        _pasteTextBuffer = string.Empty;
        _pasteTextStatus = null;
        _showPasteTextModal = true;
    }

    private void ClosePasteTextModal() => _showPasteTextModal = false;

    private async Task CopyAsTextAsync()
    {
        var text = SessionService.ExportToSummaryText();
        if (string.IsNullOrEmpty(text))
        {
            _statusIsError = true;
            _statusMessage = "Nothing to copy.";
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            _statusIsError = false;
            _statusMessage = "Copied to clipboard";
        }
        catch
        {
            // Clipboard API blocked (insecure context or permissions). Fall
            // back to the paste-text modal as a viewer with the text
            // pre-populated, so the user can manually select-and-copy.
            _pasteTextBuffer = text;
            _pasteTextStatus = "Clipboard access denied; copy from the textarea instead.";
            _pasteTextStatusIsError = false;
            _showPasteTextModal = true;
        }
    }

    private async Task ImportPastedTextAsync()
    {
        try
        {
            await Storage.ClearActiveCharacterAsync();
            var unconsumed = SessionService.ImportFromSummaryText(_pasteTextBuffer);
            _statusIsError = false;
            _statusMessage = $"Imported {SessionService.Session?.Name ?? "character"}";
            if (unconsumed.Count > 0)
                _statusMessage += $" ({unconsumed.Count} unparsed lines)";
            _showPasteTextModal = false;
            await InvokeAsync(StateHasChanged);
            Navigation.NavigateTo("/", forceLoad: false);
        }
        catch (Exception ex)
        {
            _pasteTextStatusIsError = true;
            _pasteTextStatus = $"Import failed: {ex.Message}";
        }
    }

    private void OpenPrintModal() => _showPrintModal = true;
    private void ClosePrintModal() => _showPrintModal = false;

    private bool _showDisplaySettings;
    private void OpenDisplaySettings() => _showDisplaySettings = true;
    private async Task HandleDisplaySettingsClosed()
    {
        _showDisplaySettings = false;
        await DisplaySettings.SaveAsync(JS);
    }

    private Task HandlePrintConfirm(PrintOptions options)
    {
        _showPrintModal = false;
        // In-place navigation: works in browser, MAUI BlazorWebView (Windows/
        // Mac/iOS/Android) and avoids the "external link won't open in user's
        // browser" UX problem that window.open caused on MAUI. The PrintSheet
        // page provides its own Print button (window.print) and Back button.
        var target = "/print/character" + options.ToQueryString();
        Navigation.NavigateTo(target, forceLoad: false);
        return Task.CompletedTask;
    }

    protected override void OnInitialized()
    {
        SessionService.Changed += HandleSessionChanged;
    }

    private async Task ExportCharacterAsync()
    {
        var bytes = SessionService.ExportToDnd4e();
        if (bytes is null || bytes.Length == 0)
        {
            _statusIsError = true;
            _statusMessage = "Nothing to export.";
            return;
        }

        string name = SessionService.Session?.Name ?? "character";
        string safeName = string.Concat(name.Select(ch =>
            char.IsLetterOrDigit(ch) || ch is '-' or '_' ? ch : '_'));

        _statusIsError = false;
        _statusMessage = $"Exported {name}";

        await JS.InvokeVoidAsync(
            "charm.downloadFileFromBytes",
            $"{safeName}.dnd4e",
            Convert.ToBase64String(bytes),
            "application/xml");
    }

    private async Task ImportCharacterAsync(InputFileChangeEventArgs args)
    {
        try
        {
            // Surface the loading overlay while the import runs.
            RestoreState.Set(RestorePhase.Restoring);
            await Task.Yield();

            // Clear the persistence slot before the new state lands.
            // Otherwise the import's Changed cascade races with the
            // restore path in CharacterPersistence on next reload.
            await Storage.ClearActiveCharacterAsync();
            var file = args.File;
            await using var stream = file.OpenReadStream(10 * 1024 * 1024);
            var session = await SessionService.ImportFromDnd4eAsync(stream);
            _statusIsError = false;
            _statusMessage = $"Imported {session.Name}";
            await InvokeAsync(StateHasChanged);
            Navigation.NavigateTo("/", forceLoad: false);
        }
        catch (Exception ex)
        {
            _statusIsError = true;
            _statusMessage = $"Import failed: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            RestoreState.Set(RestorePhase.Idle);
        }
    }

    private async Task StartNewCharacter()
    {
        SessionService.ClearSession();
        await Storage.ClearActiveCharacterAsync();
        _statusIsError = false;
        _statusMessage = null;
        Navigation.NavigateTo("/", forceLoad: false);
    }

    private void UndoLastChoice()
    {
        SessionService.Session?.UndoLastChoice();
        _statusIsError = false;
        _statusMessage = "Undid last choice";
    }

    private void HandleSessionChanged() => NotifyStateChanged();

    protected override void OnDispose()
    {
        SessionService.Changed -= HandleSessionChanged;
    }
}
